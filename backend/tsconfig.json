{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "~/*": ["./src/*"],
      "@db/*": ["./src/db/*"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@routes/*": ["./src/routes/*"],
      "@scripts/*": ["./src/scripts/*"],
      "@utils/*": ["./src/utils/*"],
      "@config/*": ["./src/config/*"],
    },
  },
}
